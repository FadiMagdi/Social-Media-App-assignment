<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" styleClass="auth-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.socialmediaapp.social_media_app.controller.RegisterController">

    <VBox styleClass="auth-card" spacing="12" alignment="CENTER" maxWidth="420">

        <Label text="Create Account" styleClass="auth-title"/>
        <Label text="It's quick and easy." styleClass="auth-subtitle"/>

        <Separator/>

        <Label fx:id="errorLabel" styleClass="error-label" visible="false"
               managed="false" wrapText="true"/>

        <TextField fx:id="nameField" promptText="Full Name"
                   styleClass="auth-field" maxWidth="360"/>

        <TextField fx:id="emailField" promptText="Email address"
                   styleClass="auth-field" maxWidth="360"/>

        <PasswordField fx:id="passwordField" promptText="Password"
                       styleClass="auth-field" maxWidth="360"/>

        <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password"
                       styleClass="auth-field" maxWidth="360"/>

        <TextField fx:id="ageField" promptText="Age"
                   styleClass="auth-field" maxWidth="360"/>

        <Button text="Sign Up" onAction="#handleRegister"
                styleClass="btn-secondary" maxWidth="360" prefHeight="44"
                style="-fx-font-size: 16px;"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Already have an account?"/>
            <Hyperlink text="Log In" onAction="#handleGoToLogin" styleClass="link-text"/>
        </HBox>

    </VBox>

    <padding>
        <Insets bottom="30" top="30"/>
    </padding>
</VBox>
