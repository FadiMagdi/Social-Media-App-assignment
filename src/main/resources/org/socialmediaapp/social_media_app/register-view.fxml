<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" styleClass="auth-container"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.socialmediaapp.social_media_app.controller.RegisterController">

    <VBox alignment="CENTER" styleClass="auth-container" spacing="10">

        <VBox styleClass="auth-card" spacing="12" alignment="CENTER" maxWidth="420">

            <!-- Title -->
            <Label text="Create Account" styleClass="auth-title"/>
            <Label text="It's quick and easy." styleClass="auth-subtitle"/>

            <!-- Separator -->
            <Separator/>

            <!-- Error Message -->
            <Label fx:id="errorLabel" styleClass="error-label" visible="false" managed="false"
                   wrapText="true"/>

            <!-- Name Field -->
            <TextField fx:id="nameField" promptText="Full Name" styleClass="auth-field"
                       maxWidth="360"/>

            <!-- Email Field -->
            <TextField fx:id="emailField" promptText="Email address" styleClass="auth-field"
                       maxWidth="360"/>

            <!-- Password Field -->
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="auth-field"
                           maxWidth="360"/>

            <!-- Confirm Password Field -->
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password"
                           styleClass="auth-field" maxWidth="360"/>

            <!-- Age Field -->
            <TextField fx:id="ageField" promptText="Age" styleClass="auth-field"
                       maxWidth="360"/>

            <!-- Bio Field -->
            <TextArea fx:id="bioField" promptText="Write something about yourself..."
                      prefRowCount="3" maxWidth="360" wrapText="true"
                      style="-fx-background-color: #F0F2F5; -fx-border-color: #DADDE1; -fx-border-radius: 8; -fx-background-radius: 8;"/>

            <!-- Profile Picture -->
            <HBox spacing="10" alignment="CENTER_LEFT" maxWidth="360">
                <Label text="Profile Picture:" style="-fx-text-fill: #65676B;"/>
                <Button fx:id="browseBtn" text="Browse..." onAction="#handleBrowseImage"
                        styleClass="btn-outline"/>
                <Label fx:id="imagePathLabel" text="No file selected"
                       style="-fx-text-fill: #65676B; -fx-font-size: 12px;"
                       ellipsisString="..." maxWidth="150"/>
            </HBox>

            <!-- Register Button -->
            <Button text="Sign Up" onAction="#handleRegister" styleClass="btn-secondary"
                    maxWidth="360" prefHeight="44"
                    style="-fx-font-size: 16px;"/>

            <!-- Separator -->
            <Separator>
                <padding>
                    <Insets top="3" bottom="3"/>
                </padding>
            </Separator>

            <!-- Login Link -->
            <HBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?"/>
                <Hyperlink text="Log In" onAction="#handleGoToLogin" styleClass="link-text"/>
            </HBox>

        </VBox>

        <padding>
            <Insets bottom="30"/>
        </padding>

    </VBox>

</ScrollPane>
