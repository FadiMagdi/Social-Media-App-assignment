<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.socialmediaapp.social_media_app.controller.NotificationsController">

    <padding>
        <Insets top="10" bottom="20" left="20" right="20"/>
    </padding>

    <Label text="Notifications" styleClass="section-title"/>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
        <VBox fx:id="notificationsContainer" spacing="8">
            <padding>
                <Insets top="5" bottom="10" left="5" right="5"/>
            </padding>
            <Label fx:id="noNotificationsLabel" text="No notifications yet."
                   style="-fx-text-fill: #65676B; -fx-font-size: 14px; -fx-padding: 20 0;"/>
        </VBox>
    </ScrollPane>
</VBox>
