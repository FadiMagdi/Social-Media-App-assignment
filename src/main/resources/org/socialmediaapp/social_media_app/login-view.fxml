<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" styleClass="auth-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.socialmediaapp.social_media_app.controller.LoginController">

    <VBox styleClass="auth-card" spacing="15" alignment="CENTER" maxWidth="400">

        <Label text="Social Media" styleClass="auth-title"/>
        <Label text="Connect with friends and the world around you."
               styleClass="auth-subtitle" wrapText="true" textAlignment="CENTER"/>

        <Separator/>

        <Label fx:id="errorLabel" styleClass="error-label" visible="false" managed="false"/>

        <TextField fx:id="emailField" promptText="Email address"
                   styleClass="auth-field" maxWidth="350"/>

        <PasswordField fx:id="passwordField" promptText="Password"
                       styleClass="auth-field" maxWidth="350"/>

        <Button text="Log In" onAction="#handleLogin"
                styleClass="btn-primary" maxWidth="350" prefHeight="44"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Don't have an account?"/>
            <Hyperlink text="Create New Account" onAction="#handleGoToRegister"
                       styleClass="link-text"/>
        </HBox>

    </VBox>
</VBox>
