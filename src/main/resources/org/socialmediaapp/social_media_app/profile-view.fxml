<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.socialmediaapp.social_media_app.controller.ProfileController">

    <VBox spacing="15" alignment="TOP_CENTER">
        <padding>
            <Insets top="10" bottom="20" left="40" right="40"/>
        </padding>

        <!-- Profile Header Card -->
        <VBox styleClass="profile-header" spacing="15" alignment="CENTER" maxWidth="600">

            <!-- Profile Picture -->
            <StackPane minWidth="100" minHeight="100" maxWidth="100" maxHeight="100">
                <ImageView fx:id="profileImageView" fitWidth="100" fitHeight="100"
                           preserveRatio="true" styleClass="profile-picture"/>
                <!-- Fallback avatar circle -->
                <VBox fx:id="avatarFallback" alignment="CENTER" minWidth="100" minHeight="100"
                      maxWidth="100" maxHeight="100"
                      style="-fx-background-color: #1877F2; -fx-background-radius: 50;">
                    <Label fx:id="profileInitial" text="U"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 36px;"/>
                </VBox>
            </StackPane>

            <!-- Name -->
            <Label fx:id="profileNameLabel" text="User Name" styleClass="profile-name"/>

            <!-- Bio -->
            <Label fx:id="profileBioLabel" text="No bio yet" styleClass="profile-bio"
                   wrapText="true" maxWidth="500"/>

            <!-- Stats -->
            <HBox styleClass="profile-stats" spacing="40" alignment="CENTER">
                <VBox alignment="CENTER" spacing="2">
                    <Label fx:id="profileEmailLabel" text="email@example.com"
                           style="-fx-font-size: 13px; -fx-text-fill: #65676B;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2">
                    <Label fx:id="profileAgeLabel" text="Age: 0"
                           style="-fx-font-size: 13px; -fx-text-fill: #65676B;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2">
                    <Label fx:id="friendsCountLabel" text="0" styleClass="profile-stat-value"/>
                    <Label text="Friends" styleClass="profile-stat-label"/>
                </VBox>
            </HBox>

            <!-- Action Buttons -->
            <HBox fx:id="actionButtonsBox" spacing="10" alignment="CENTER">
                <!-- Edit Profile (own profile) -->
                <Button fx:id="editProfileBtn" text="Edit Profile" onAction="#handleEditProfile"
                        styleClass="btn-primary" visible="false" managed="false"/>
                <!-- Add Friend (other user's profile) -->
                <Button fx:id="addFriendBtn" text="Add Friend" onAction="#handleAddFriend"
                        styleClass="btn-secondary" visible="false" managed="false"/>
            </HBox>
        </VBox>

        <!-- Separator -->
        <Separator maxWidth="600"/>

        <!-- Posts Section Title -->
        <Label text="Posts" styleClass="section-title" maxWidth="600"
               style="-fx-padding: 5 0 0 0;"/>

        <!-- User's Posts -->
        <VBox fx:id="userPostsContainer" spacing="15" alignment="TOP_CENTER" maxWidth="600">
            <Label fx:id="noPostsLabel" text="No posts yet."
                   style="-fx-text-fill: #65676B; -fx-font-size: 14px; -fx-padding: 20 0;"/>
        </VBox>

    </VBox>

</ScrollPane>
